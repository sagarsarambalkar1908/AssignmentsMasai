name = input("Enter student name")
subject1 = float(input("Enter marks for 1st subject "))
subject2 = float(input("Enter marks for 2nd subject "))
subject3 = float(input("Enter marks for 3rd subject "))
total = subject1 + subject2 + subject3 
percentage = (total/300) * 100
def getpercentage(args):
    if args < 40.00:
        return 'F'
    elif args >=40.00 and args <= 60.00:
        return 'C'
    elif args >= 60.00 and args < 75.00:
        return 'B'
    elif args >=75.00:
        return 'A'
grade = getpercentage(percentage)

print(f"Student name {name}")
print(f"Student marks subject1 = {subject1}, subject2 = {subject2}, subject3 = {subject3}")
print(f"Student marks total {total}")
print(f"Student got {percentage}%")
print(f"Student got passed with {grade}")
